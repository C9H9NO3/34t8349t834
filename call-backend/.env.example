# Copy to .env for local dev. On Railway, set these as service variables
# instead (do NOT commit real secrets).

# --- Transcription / intent (required for live transcripts) ---
OPENAI_API_KEY=sk-...

# --- NodeMaven residential proxy (keep ON so Google login egresses from a
#     residential IP, not the datacenter). ---
PROXY_ENABLED=true
NODEMAVEN_USER=your_nodemaven_user
NODEMAVEN_PASS=your_nodemaven_pass
# Optional proxy tuning (defaults shown):
# PROXY_BRIDGE=true
# PROXY_USE_SOCKS5=true
# PROXY_USE_BUNDLED_CHROMIUM=true
# PROXY_SPEED_FAST=true

# --- Telegram notifications (optional; CHAT_ID resolves from getUpdates if blank) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Hosting (Railway) ---
# Password gate for the dashboard + WS + remote-login. LEAVE BLANK locally to
# disable auth; set a strong value in production.
DASHBOARD_PASSWORD=
# Persistent state dir. Locally defaults to the backend folder; on Railway mount
# a volume and set DATA_DIR to its path.
# DATA_DIR=/data
# Force bundled Chromium (no system Chrome on Linux hosts).
# STEALTH_CHANNEL=bundled
# Send ONLY the injected WAV (no real-mic mixing). Defaults true on Linux hosts.
# INJECT_MICLESS=true
# Railway injects PORT automatically; HOST defaults to 0.0.0.0.
# PORT=8787
# HOST=0.0.0.0
